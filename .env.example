# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Flutterwave — get from https://dashboard.flutterwave.com/settings/apis
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your-key-here
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your-secret-here
FLUTTERWAVE_ENCRYPTION_KEY=your-encryption-key-here

# ─────────────────────────────────────────────────────────────
# M-PESA DARAJA API — https://developer.safaricom.co.ke
# ─────────────────────────────────────────────────────────────
# 1. Go to https://developer.safaricom.co.ke → Create App
# 2. Subscribe to "Lipa Na M-Pesa Online" (STK Push) API
# 3. Copy Consumer Key and Consumer Secret from your app
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret

# Your Paybill or Till number (use 174379 for sandbox testing)
MPESA_SHORTCODE=174379

# Passkey from Safaricom (use test passkey for sandbox)
# Sandbox passkey: bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# 'sandbox' for testing, 'production' for live
MPESA_ENV=sandbox

# App
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Zawadi

# Escrow wallet (Flutterwave virtual account or your own bank account)
ESCROW_ACCOUNT_BANK_CODE=044
ESCROW_ACCOUNT_NUMBER=your-escrow-account-number
